# Copy to frontend/.env and fill in. Prefer per-network keys so Sepolia and Hardhat
# never share the wrong contract pair.

# --- Sepolia (11155111) — prefer these ---
# VITE_SEPOLIA_TOKEN_ADDRESS=0x...
# VITE_SEPOLIA_STAKING_POOL_ADDRESS=0x...

# Legacy single-network names (Sepolia only; still supported):
# VITE_TOKEN_ADDRESS=0x...
# VITE_STAKING_POOL_ADDRESS=0x...

# --- Local Hardhat (31337) — required for local unless you use deploy script output ---
# VITE_HARDHAT_TOKEN_ADDRESS=0x...
# VITE_HARDHAT_STAKING_POOL_ADDRESS=0x...

# After `npx hardhat run scripts/deploy.ts --network hardhat` (chain 31337), the deploy
# script writes frontend/public/deployments.json; in `npm run dev` the app loads it
# automatically (no Hardhat env vars needed in development).

VITE_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_WALLETCONNECT_PROJECT_ID=
